# Copy to .env (never commit real keys). All optional — app runs without them.
SEC_USER_AGENT=YourFirm research you@yourfirm.com   # enables free SEC EDGAR source
SERPER_API_KEY=                                      # https://serper.dev  (news enrichment)
APOLLO_API_KEY=                                      # https://apollo.io   (contact enrichment)
ADMIN_TOKEN=choose-a-long-random-string              # protects POST /admin/refresh
